# Chaves de API dos providers (cobrança por TOKEN — não é a assinatura Pro/Max).
# Copie para `.env` e preencha as que você usa. O loopforge carrega o `.env`
# automaticamente ao rodar. Variáveis já exportadas no shell têm precedência.
#
# `.env` está no .gitignore — não comite suas chaves.

# Anthropic (modelos anthropic:...) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini (modelos google-gla:...) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (alternativa aceita pelo provider) GOOGLE_API_KEY=

# OpenAI (modelos openai:...) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
