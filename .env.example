# Chaves de API dos providers (cobrança por TOKEN — não é a assinatura Pro/Max).
# Copie para `.env` e preencha as que você usa. O loopforge carrega o `.env`
# automaticamente ao rodar. Variáveis já exportadas no shell têm precedência.
#
# `.env` está no .gitignore — não comite suas chaves.

# OpenRouter (modelos openrouter:...; inclui modelos :free) — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# NVIDIA NIM (modelos nvidia:...; API gratuita) — https://build.nvidia.com (chave nvapi-...)
# NVIDIA_API_KEY=

# Anthropic (modelos anthropic:...) — https://console.anthropic.com
# ANTHROPIC_API_KEY=

# Google Gemini (modelos google-gla:...) — https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# (alternativa aceita pelo provider) GOOGLE_API_KEY=

# OpenAI (modelos openai:...) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# MCP local de Confluence (server `atlassian` em ./.mcp.json) — usado pelo
# Discovery p/ ler os esquemas do AI Brain. Atlassian Cloud = email + API token.
# Crie o token em https://id.atlassian.com/manage-profile/security/api-tokens
# -----------------------------------------------------------------------------
# CONFLUENCE_URL=
# CONFLUENCE_USERNAME=
# CONFLUENCE_API_TOKEN=
